# Copy this file to .env and fill in real values.

# MongoDB connection string. If omitted, an in-memory MongoDB instance is
# spun up automatically for local development (data is NOT persisted
# between restarts in that mode).
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/mydb?retryWrites=true&w=majority

PORT=5000

# Secret used to sign/verify JWTs. REQUIRED in production. If left blank,
# the server generates a random ephemeral secret on each boot (dev only —
# existing tokens are invalidated on every restart).
JWT_SECRET=replace_with_a_long_random_string

# Gemini 2.5 Flash API key used for AI itinerary generation.


# Origin allowed to call this API (your deployed frontend URL).
# Leave unset during local development to allow all origins.
CLIENT_URL=http://localhost:3000
